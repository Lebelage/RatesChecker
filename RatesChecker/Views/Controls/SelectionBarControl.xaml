<UserControl x:Class="RatesChecker.Views.Controls.SelectionBarControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:RatesChecker.ViewModels"
             xmlns:local="clr-namespace:RatesChecker.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:SelectionBarControlViewModel/>
    </UserControl.DataContext>
    <Grid>
        <Border BorderThickness="2" Margin="5" CornerRadius="3" BorderBrush="{StaticResource brush_MainBorder}">
            <StackPanel>
                <Button Content="Rates online" Margin="5" Command="{Binding OpenWorkplaceCurrencyStreamingViewCommand}" IsEnabled="{Binding IsCurrencyStreamingButtonEnable}" Style="{StaticResource FlatSideMenuButton}"/>
                <Button Content="Rates from file"  Margin="5" Command="{Binding OpenWorkplaceCurrencyEditorViewCommand}" IsEnabled="{Binding IsCurrencyEditorButtonEnable}" Style="{StaticResource FlatSideMenuButton}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
