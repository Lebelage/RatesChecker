<UserControl x:Class="RatesChecker.Views.Controls.Workplace_CurrencyStreamingControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:RatesChecker.ViewModels.WorkplaceControlsViewModels"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:local="clr-namespace:RatesChecker.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:CurrencyStreamingControlViewModel/>
    </UserControl.DataContext>

    <DockPanel>
        <Grid DockPanel.Dock="Top" Height="35" VerticalAlignment="Top">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="130"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="100"/>
                <ColumnDefinition Width="100"/>
            </Grid.ColumnDefinitions>
     
            <ComboBox Grid.Column="0" Height="25" ItemsSource="{Binding CurrenciesAbbreviationList}" SelectedItem="{Binding SelectedCurrency}" Style="{StaticResource RoundedComboBoxStyle}" Tag="Select currency"/>
            <ComboBox Grid.Column="1" Height="25" ItemsSource="{Binding DynamicPeriodsList}" SelectedItem="{Binding SelectedDynamicPeriod}" Style="{StaticResource RoundedComboBoxStyle}"/>
            <Button Content="Save in file" Grid.Column="3" Height="25" Command="{Binding SaveCurrencyDynamicDataToJsonCommand}" Style="{StaticResource button_CommonRounded}"/>
            <Button Content="{Binding ShowTableOrPlotButtonContent}" Grid.Column="4" Height="25" Command="{Binding ChangePlotVisibilityCommand}" Style="{StaticResource button_CommonRounded}"/>
        </Grid>
        <DataGrid DockPanel.Dock="Top" ItemsSource="{Binding SelectedCurrencyDynamicList}" IsReadOnly="True" Visibility="{Binding DataGridVisibility}" Margin="5"/>
        <oxy:PlotView Model="{Binding CurrencyPlotModel}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch" Visibility="{Binding PlotVisibility}" Margin="5"/>
    </DockPanel>
</UserControl>
