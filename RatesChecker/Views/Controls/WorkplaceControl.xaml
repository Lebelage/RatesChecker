<UserControl x:Class="RatesChecker.Views.Controls.WorkplaceControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:RatesChecker.Views.Controls"
             xmlns:vm="clr-namespace:RatesChecker.ViewModels.WorkplaceControlsViewModels"
             xmlns:controls="clr-namespace:RatesChecker.Views.Controls"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.DataContext>
        <vm:WorkplaceControlViewModel/>
    </UserControl.DataContext>
    <DockPanel>
        <Border BorderThickness="2" BorderBrush="{StaticResource brush_MainBorder}" Margin="5" CornerRadius="3">
            <ContentControl Content="{Binding CurrentView}"/>
        </Border>
    </DockPanel>
</UserControl>
